<form class="co2m-layout" autocomplete="off">

  {{!-- HEADER --}}
  <header class="co2m-merchant-header">
    <img src="{{actor.img}}" class="co2m-merchant-avatar" alt="{{actor.name}}">
    <div class="co2m-merchant-info">
      <h2 class="co2m-merchant-name">{{actor.name}}</h2>
      <div class="co2m-merchant-status">

        <button type="button" data-action="toggleActive"
                class="co2m-btn {{#if isActive}}status-active{{else}}status-inactive{{/if}}">
          <i class="fas fa-{{#if isActive}}store{{else}}store-slash{{/if}}"></i>
          {{#if isActive}}Boutique ouverte{{else}}Boutique fermée{{/if}}
        </button>

        <button type="button" data-action="showPlayers" class="co2m-btn">
          <i class="fas fa-users"></i> Afficher aux joueurs
        </button>

        <button type="button" data-action="openShop" class="co2m-btn">
          <i class="fas fa-eye"></i> Aperçu joueur
        </button>

        <span class="co2m-modifier-badge {{#if (gt modifier 0)}}positive{{else if (lt modifier 0)}}negative{{else}}neutral{{/if}}">
          <i class="fas fa-percent"></i> {{modifier}}%
        </span>

      </div>
    </div>
  </header>

  {{!-- PARAMÈTRES --}}
  <section class="co2m-settings">
    <div class="co2m-settings-grid">

      <div class="co2m-setting-group">
        <label class="co2m-setting-label"><i class="fas fa-tags"></i> Modificateur</label>
        <input type="number" name="modifier" value="{{modifier}}" min="-99" max="500" step="5" class="co2m-input">
        <span class="co2m-setting-unit">%</span>
      </div>

      <div class="co2m-setting-group">
        <label class="co2m-setting-label"><i class="fas fa-hand-holding-usd"></i> Rachat</label>
        <input type="number" name="buyback" value="{{buyback}}" min="0" max="100" step="5" class="co2m-input">
        <span class="co2m-setting-unit">%</span>
      </div>

      <div class="co2m-setting-group">
        <label class="co2m-setting-label"><i class="fas fa-coins"></i> Bourse</label>
        <input type="number" name="purse" value="{{purseGP}}" min="0" step="0.01" class="co2m-input">
        <span class="co2m-setting-unit">PO</span>
      </div>

      <div class="co2m-setting-group">
        <label class="co2m-setting-label">
          <input type="checkbox" name="infinite" {{#if infinite}}checked{{/if}}>
          <i class="fas fa-infinity"></i> Stock infini
        </label>
      </div>

      <div class="co2m-setting-group">
        <label class="co2m-setting-label">
          <input type="checkbox" name="showPurse" {{#if showPurse}}checked{{/if}}>
          <i class="fas fa-eye"></i> Afficher bourse
        </label>
      </div>

    </div>
    <div class="co2m-settings-actions">
      <button type="submit" data-action="saveSettings" class="co2m-btn">
        <i class="fas fa-save"></i> Sauvegarder
      </button>
    </div>
  </section>

  {{!-- INVENTAIRE --}}
  <section class="co2m-inventory-section">

    <div class="co2m-inventory-header">
      <h3><i class="fas fa-boxes"></i> Inventaire ({{itemCount}} objets)</h3>
    </div>

    <div class="co2m-inventory-body">

      {{#each inventoryGroups}}
      <div class="co2m-group" data-subtype="{{subtype}}">

        <div class="co2m-group-header co2m-group-toggle" data-group="{{subtype}}">
          <i class="fas fa-chevron-down co2m-group-chevron"></i>
          <i class="fas {{icon}}"></i>
          <span class="co2m-group-label">{{label}}</span>
          <span class="co2m-group-count">({{items.length}})</span>
        </div>

        <div class="co2m-group-body">
          <table class="co2m-table">
            <thead>
              <tr>
                <th></th>
                <th>Objet</th>
                <th>Qté</th>
                <th>Natif</th>
                <th>Réf.</th>
                <th>Vente</th>
                <th>Rachat</th>
                <th></th>
              </tr>
            </thead>
            <tbody>
              {{#each items}}
              <tr data-item-id="{{id}}">
                <td>
                  <img src="{{img}}" class="co2m-item-icon co2m-info-trigger"
                       data-item-name="{{name}}"
                       data-item-description="{{description}}">
                </td>
                <td class="{{#if hasOverride}}co2m-has-override{{/if}}">{{name}}</td>
                <td>{{quantity}}</td>
                <td>{{nativePriceStr}}</td>
                <td>{{basePriceStr}}</td>
                <td>{{finalSellStr}}</td>
                <td>{{finalBuyStr}}</td>
                <td class="co2m-item-actions">
                  <button type="button" data-action="editPrice" class="co2m-btn" title="Modifier le prix">
                    <i class="fas fa-pen"></i>
                  </button>
                  <button type="button" data-action="removeItem" class="co2m-btn" title="Retirer">
                    <i class="fas fa-trash"></i>
                  </button>
                </td>
              </tr>
              {{/each}}
            </tbody>
          </table>
        </div>

      </div>
      {{/each}}

      {{#unless inventoryGroups}}
      <p class="co2m-empty"><i class="fas fa-box-open"></i> Inventaire vide — glissez des objets depuis le compendium.</p>
      {{/unless}}

    </div>
  </section>

  {{!-- Tooltip (inside form = single root element) --}}
  <div class="co2m-tooltip" style="display:none;"></div>

</form>
